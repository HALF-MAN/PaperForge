# PaperForge environment template
# Copy this file to .env.local and fill in only the providers you use.
# Never commit real API keys or exchange credentials.

# -----------------------------------------------------------------------------
# Application services
# -----------------------------------------------------------------------------

# Python Agent Runtime used by Next.js server routes.
PAPERFORGE_PY_BACKEND_URL=http://127.0.0.1:8765

# Maximum time that the Strategy Lab Next.js proxy waits for Python, in ms.
# Keep this slightly higher than STRATEGY_LAB_LLM_TIMEOUT_SEC.
STRATEGY_LAB_PROXY_TIMEOUT_MS=130000

# Optional shared SQLite path for sessions, strategies, skills and research cards.
# Relative paths are resolved from the repository root.
PAPERFORGE_DB_PATH=.paperforge/platform.sqlite

# -----------------------------------------------------------------------------
# Agent LLM
# -----------------------------------------------------------------------------

# Supported values: dashscope, openai-compatible, none.
# Use none to disable LLM-backed Strategy Lab turns.
LLM_PROVIDER=dashscope

# DashScope OpenAI-compatible API configuration.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=deepseek-v4-pro

# Timeout for research, intent routing and normal Agent turns, in seconds.
STRATEGY_LAB_LLM_TIMEOUT_SEC=90

# Optional dedicated model for Python strategy generation.
# Resolution order: STRATEGY_LAB_CODE_MODEL, provider-specific code model,
# then the runtime default.
STRATEGY_LAB_CODE_MODEL=kimi-k2.7-code
DASHSCOPE_CODE_MODEL=
STRATEGY_LAB_CODE_LLM_TIMEOUT_SEC=90

# Alternative OpenAI-compatible provider. Set LLM_PROVIDER=openai-compatible
# and configure these values instead of the DashScope block above.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_CODE_MODEL=

# -----------------------------------------------------------------------------
# Public crypto research data
# -----------------------------------------------------------------------------

# Optional. Without this key PaperForge uses CoinMarketCap's rate-limited
# keyless endpoints. Coin Metrics community data and mempool.space need no key.
CMC_API_KEY=

# -----------------------------------------------------------------------------
# Bitget MCP and exchange access
# -----------------------------------------------------------------------------

# Optional path or executable name for bitget-mcp-server.
# Leave empty to use node_modules/.bin/bitget-mcp-server, with npx fallback.
BITGET_MCP_COMMAND=

# Optional private Bitget credentials. Public ticker, candles, funding rate,
# open interest and order-book research do not require them.
# PaperForge currently keeps the integration read-only and never places orders.
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=
BITGET_MODE=read_only
