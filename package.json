{
  "name": "paperforge",
  "version": "0.1.0",
  "private": true,
  "description": "AI workspace for evidence-backed crypto strategy research and sandbox backtesting.",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
